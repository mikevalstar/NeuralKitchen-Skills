generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Skill {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String
  dirPath       String
  license       String?
  compatibility String?
  meta          Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tags          Tag[]
  projects      ProjectSkill[]
  notifications Notification[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skills    Skill[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  branchName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skills        ProjectSkill[]
  notifications Notification[]
}

model ProjectSkill {
  id        String   @id @default(cuid())
  projectId String
  skillId   String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
}

model Notification {
  id            String   @id @default(cuid())
  projectId     String
  skillId       String
  fromCommitSha String
  toCommitSha   String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill         Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId, toCommitSha])
  @@index([projectId, read])
}
